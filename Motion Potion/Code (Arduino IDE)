#include <Wire.h>
#include <MPU6050.h>
MPU6050 mpu;
#define ALPHA 0.96
#define LOW_PASS 0.1
#define DEAD_ZONE 0.8
#define SEND_INTERVAL 30
float pitch = 0, roll = 0, yaw = 0;
float filtPitch = 0, filtRoll = 0, filtYaw = 0;
unsigned long lastTime = 0;
unsigned long lastSend = 0;
void setup() {
Serial.begin(115200);
Wire.begin(5, 4); // SDA = 5 and SCL = 4
mpu.initialize();
if (mpu.testConnection()) {
Serial.println("MPU6050 connected!");
} else {
Serial.println("MPU6050 connection failed!");
}
mpu.setXGyroOffset(0);
mpu.setYGyroOffset(0);
mpu.setZGyroOffset(0);
mpu.setXAccelOffset(0);
mpu.setYAccelOffset(0);
mpu.setZAccelOffset(0);
lastTime = millis();
}
void loop() {
unsigned long now = millis();
float dt = (now - lastTime) / 1000.0;
lastTime = now;
int16_t ax, ay, az, gx, gy, gz;
mpu.getMotion6(&ax, &ay, &az, &gx, &gy, &gz);
float gyroX = gx / 131.0;
float gyroY = gy / 131.0;
float gyroZ = gz / 131.0;
float accelPitch = atan2(ay, az) * 180.0 / PI;
float accelRoll = atan2(ax, az) * 180.0 / PI;
pitch = ALPHA * (pitch + gyroX * dt) + (1.0 - ALPHA) * accelPitch;
roll = ALPHA * (roll + gyroY * dt) + (1.0 - ALPHA) * accelRoll;
yaw += gyroZ * dt;
filtPitch = LOW_PASS * pitch + (1.0 - LOW_PASS) * filtPitch;
filtRoll = LOW_PASS * roll + (1.0 - LOW_PASS) * filtRoll;
filtYaw = LOW_PASS * yaw + (1.0 - LOW_PASS) * filtYaw;
static float lastSentPitch = 0, lastSentRoll = 0, lastSentYaw = 0;
bool changed = abs(filtPitch - lastSentPitch) > DEAD_ZONE || abs(filtRoll - lastSentRoll) > DEAD_ZONE || abs(filtYaw - lastSentYaw) > DEAD_ZONE;
if ((now - lastSend >= SEND_INTERVAL) && changed) {
Serial.print(filtPitch); Serial.print(",");
Serial.print(filtRoll); Serial.print(",");
Serial.println(filtYaw);
lastSentPitch = filtPitch;
lastSentRoll = filtRoll;
lastSentYaw = filtYaw;
lastSend = now;
}
}
